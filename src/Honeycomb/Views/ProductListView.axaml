<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Honeycomb.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Honeycomb.Views.ProductListView"
             x:DataType="vm:ProductListViewModel">

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">

        <!-- Add Product Form -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <WrapPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="商品名稱" Margin="0,0,0,4"/>
                    <TextBox Watermark="商品名稱" Text="{Binding NewName}" Width="150"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="數量" Margin="0,0,0,4"/>
                    <NumericUpDown Value="{Binding NewQuantity}" Minimum="1" Increment="1" FormatString="0" ShowButtonSpinner="False" Width="80"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="單價" Margin="0,0,0,4"/>
                    <NumericUpDown Value="{Binding NewUnitPrice}" Minimum="0" Increment="1" FormatString="N2" ShowButtonSpinner="False" Width="100"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="幣別" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Currencies}"
                              SelectedItem="{Binding NewCurrency}"
                              Width="120">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Code}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="匯率" Margin="0,0,0,4"/>
                    <NumericUpDown Value="{Binding NewExchangeRate}" Minimum="0" Increment="0.01" FormatString="N4" ShowButtonSpinner="False" Width="100"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="折扣" Margin="0,0,0,4"/>
                    <NumericUpDown Value="{Binding NewDiscount}" Minimum="0.01" Maximum="1" Increment="0.05" FormatString="N2" ShowButtonSpinner="False" Width="80"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,8" VerticalAlignment="Bottom">
                    <Button Content="新增商品" Command="{Binding AddProductCommand}" Margin="0,0,0,0"/>
                </StackPanel>
            </WrapPanel>
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{Binding CostPricePreview}" Foreground="#66BB6A"/>
                <TextBlock Text="{Binding TotalPricePreview}" Foreground="#42A5F5"/>
            </StackPanel>
        </StackPanel>

        <!-- Product DataGrid -->
        <DataGrid Grid.Row="1"
                  Name="ProductGrid"
                  ItemsSource="{Binding Products}"
                  SelectionMode="Extended"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="商品名稱" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="數量" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="單價" Binding="{Binding UnitPrice, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="幣別" Binding="{Binding Currency.Code}" Width="80"/>
                <DataGridTextColumn Header="匯率" Binding="{Binding ExchangeRate, StringFormat=N4}" Width="100"/>
                <DataGridTextColumn Header="折扣" Binding="{Binding Discount, StringFormat=N2}" Width="80"/>
                <DataGridTextColumn Header="成本價" Binding="{Binding CostPrice, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="總價" Binding="{Binding TotalPrice, StringFormat=N2}" Width="120"/>
                <DataGridTextColumn Header="建立時間" Binding="{Binding CreatedAt, StringFormat=yyyy/MM/dd}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom Bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
            <Button Content="刪除選取的商品" Click="OnDeleteClicked"/>
            <Button Content="匯出 Excel" Command="{Binding ExportExcelCommand}"/>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" VerticalAlignment="Center"/>
        </StackPanel>

    </Grid>
</UserControl>
