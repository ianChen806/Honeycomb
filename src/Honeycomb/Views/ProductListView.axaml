<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Honeycomb.ViewModels"
             xmlns:models="using:Honeycomb.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="600"
             x:Class="Honeycomb.Views.ProductListView"
             x:DataType="vm:ProductListViewModel">

    <Grid RowDefinitions="Auto,*,Auto" Margin="16" Background="Transparent" PointerPressed="OnBackgroundPressed">

        <!-- Add Product Form -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <WrapPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="商品名稱" Margin="0,0,0,4"/>
                    <TextBox Watermark="商品名稱" Text="{Binding NewName}" Width="150"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="單價" Margin="0,0,0,4"/>
                    <NumericUpDown Value="{Binding NewUnitPrice}" Minimum="0" Increment="1" FormatString="N2" ShowButtonSpinner="False" Width="100"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="幣別" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Currencies}"
                              SelectedItem="{Binding NewCurrency}"
                              Width="120">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:Currency">
                                <TextBlock Text="{Binding Code}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="匯率" Margin="0,0,0,4"/>
                    <NumericUpDown Value="{Binding NewExchangeRate}" Minimum="0" Increment="0.01" FormatString="N2" ShowButtonSpinner="False" Width="100"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="額外成本" Margin="0,0,0,4"/>
                    <NumericUpDown Value="{Binding NewExtraCost}" Minimum="0" Increment="10" FormatString="N0" ShowButtonSpinner="False" Width="100"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="折扣" Margin="0,0,0,4"/>
                    <NumericUpDown Value="{Binding NewDiscount}" Minimum="0" Maximum="1" Increment="0.05" FormatString="N2" ShowButtonSpinner="False" Width="80"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="上架價格" Margin="0,0,0,4"/>
                    <NumericUpDown Value="{Binding NewListingPrice}" Minimum="0" Increment="1" FormatString="0" ShowButtonSpinner="False" Width="100"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="手續費(%)" Margin="0,0,0,4"/>
                    <NumericUpDown Value="{Binding NewCommissionFee}" Minimum="0" Increment="1" FormatString="0" ShowButtonSpinner="False" Width="80"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,8" VerticalAlignment="Bottom">
                    <Button Content="新增商品" Command="{Binding AddProductCommand}" Margin="0,0,0,0"/>
                </StackPanel>
            </WrapPanel>
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{Binding CostPricePreview}" Foreground="#66BB6A"/>
                <TextBlock Text="{Binding ProfitPreview}" Foreground="#42A5F5"/>
                <TextBlock Text="{Binding ProfitMarginPreview}" Foreground="#AB47BC"/>
            </StackPanel>
        </StackPanel>

        <!-- Product DataGrid -->
        <DataGrid Grid.Row="1"
                  Name="ProductGrid"
                  ItemsSource="{Binding Products}"
                  SelectionMode="Extended"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  CellEditEnding="OnCellEditEnding">
            <DataGrid.Resources>
                <x:Double x:Key="DataGridSortIconMinWidth">12</x:Double>
            </DataGrid.Resources>
            <DataGrid.Styles>
                <Style Selector="DataGridRow:nth-child(even)">
                    <Setter Property="Background" Value="{DynamicResource SystemListLowColor}"/>
                </Style>
            </DataGrid.Styles>
            <DataGrid.Columns>
                <DataGridTextColumn Header="商品名稱" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="單價" Binding="{Binding UnitPrice, StringFormat=N2}" Width="100"/>
                <DataGridTemplateColumn Header="幣別" Width="100" SortMemberPath="Currency.Code">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:Product">
                            <TextBlock Text="{Binding Currency.Code}" VerticalAlignment="Center" Margin="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate x:CompileBindings="False">
                            <ComboBox ItemsSource="{Binding DataContext.Currencies, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding Currency}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Code}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="匯率" Binding="{Binding ExchangeRate, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="額外成本" Binding="{Binding ExtraCost, StringFormat=N0}" Width="100"/>
                <DataGridTextColumn Header="折扣" Binding="{Binding Discount, StringFormat=N2}" Width="80"/>
                <DataGridTextColumn Header="上架價格" Binding="{Binding ListingPrice, StringFormat=0}" Width="100"/>
                <DataGridTextColumn Header="手續費(%)" Binding="{Binding CommissionFee, StringFormat=0}" Width="80"/>
                <DataGridTextColumn Header="成本價" Binding="{Binding CostPrice, StringFormat=N2}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="利潤" Binding="{Binding Profit, StringFormat=N2}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="利潤率(%)" Binding="{Binding ProfitMargin, StringFormat={}{0:N2}%}" Width="80" IsReadOnly="True"/>
                <DataGridTextColumn Header="建立時間" Binding="{Binding CreatedAt, StringFormat=yyyy/MM/dd}" Width="120" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Floating Search Overlay -->
        <Border Grid.Row="1"
                IsVisible="{Binding IsSearchVisible}"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,16,0" Padding="8" CornerRadius="6"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BoxShadow="0 2 8 0 #40000000">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox Name="SearchBox" Width="200" Watermark="搜尋商品名稱"
                         Text="{Binding SearchQuery}" KeyDown="OnSearchKeyDown"/>
                <TextBlock Text="{Binding MatchCountText}" VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                <Button Content="↑" ToolTip.Tip="上一筆 (Shift+Enter)" Click="OnPreviousMatchClicked"/>
                <Button Content="↓" ToolTip.Tip="下一筆 (Enter)" Click="OnNextMatchClicked"/>
                <Button Content="✕" ToolTip.Tip="關閉 (Esc)" Click="OnCloseSearchClicked"/>
            </StackPanel>
        </Border>

        <!-- Bottom Bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
            <Button Content="刪除選取的商品" Click="OnDeleteClicked"/>
            <Button Content="移動到分類" Click="OnMoveCategoryClicked"/>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" VerticalAlignment="Center"/>
        </StackPanel>

    </Grid>
</UserControl>
